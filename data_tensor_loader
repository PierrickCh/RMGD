import os
import torch

import dataset_loader
device = torch.device('cuda:0' if torch.cuda.is_available() else 'cpu')

##### MAIN PARAMETERS
""" Availible datasets :
celeba
cifar
fashion
art
cat
dog
grumpy
obama
panda
flickr
mnist
"""

data_dir = ".data"
data_set_name = "celeba"
force_reload_tensor = False
subset_name = None



# Handle assigning the right dataset number to each datasets and its corresponding loading function to be used
assigned_data_set = -1
loading_func = None
match data_set_name:
    case "celeba"   : assigned_data_set = 0     ;   loading_func = dataset_loader.load_celeba          ;    root_appendix = None
    case "cifar"    : assigned_data_set = 1     ;   loading_func = dataset_loader.load_cifar10         ;    root_appendix = None
    case "fashion"  : assigned_data_set = 2     ;   loading_func = dataset_loader.load_mnist_fashion   ;    root_appendix = None
    case "art"      : assigned_data_set = 3     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-art-painting"
    case "cat"      : assigned_data_set = 4     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-cat"
    case "dog"      : assigned_data_set = 5     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-dog"
    case "grumpy"   : assigned_data_set = 6     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-grumpy-cat"
    case "obama"    : assigned_data_set = 7     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-obama"
    case "panda"    : assigned_data_set = 8     ;   loading_func = dataset_loader.load_parquet         ;    root_appendix = "few-shot-panda"
    case "flickr"   : assigned_data_set = 9     ;   loading_func = dataset_loader.load_jpg_folder      ;    root_appendix = None
    case "mnist"    : assigned_data_set = 10    ;   loading_func = dataset_loader.load_mnist           ;    root_appendix = None

kwargs = {
    "root" : os.path.join(data_dir, root_appendix if root_appendix is not None else ""),
    "num_samples" : 150,
    "target_labels" : [],
    "image_size" : 32,    
}

full_name = f"{data_set_name}_{subset_name}_{assigned_data_set}"


torch.cuda.empty_cache()

# loading/saving of cahce
cache_dir = f"{data_dir}/saved_tensors"
os.makedirs(cache_dir, exist_ok=True)

status_file = os.path.join(cache_dir, "last_run_data.txt")
tensor_file = os.path.join(cache_dir, f"tensor_cache_{full_name}.pt")

load_from_cache = False

if not force_reload_tensor and os.path.exists(status_file) and os.path.exists(status_file):
    with open(status_file, 'r') as f:
        last_set = f.read().strip()
        if last_set == str(assigned_data_set) or os.path.exists(tensor_file):
            load_from_cache = True

if load_from_cache:
    print(f"Loading tensor from : {tensor_file}")
    data_tensor = torch.load(tensor_file, map_location=device)

else:
    print(f"Processing dataset {data_set_name} and creating tensor file ({tensor_file})")
    data_tensor = loading_func(**kwargs)
    # Save the tensor and update the file
    torch.save(data_tensor, tensor_file)
    with open(status_file, 'w') as f:
        f.write(f"{assigned_data_set}")


